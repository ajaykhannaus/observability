{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Azure Monitor Prometheus endpoint",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "barchart",
      "name": "Bar chart",
      "version": ""
    },
    {
      "type": "panel",
      "id": "piechart",
      "name": "Pie chart",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "AI Gateway telemetry — request volume, latency, cost, tokens, errors",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["ai", "telemetry", "llm"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Data source",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": {"from": "now-3h", "to": "now"},
  "timepicker": {},
  "timezone": "utc",
  "title": "AI Gateway Telemetry",
  "uid": "ai-telemetry-poc-001",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Requests (24 h)",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(increase(ai_gateway_request_count_total[24h]))",
          "legendFormat": "Requests",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Avg Latency p50",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1500},
              {"color": "red", "value": 3000}
            ]
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.50, sum(rate(ai_gateway_request_duration_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Cost (24 h)",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(increase(ai_gateway_request_cost_total[24h]))",
          "legendFormat": "Cost",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Error Rate",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.01},
              {"color": "red", "value": 0.05}
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(ai_gateway_exception_count_total[5m])) / sum(rate(ai_gateway_request_count_total[5m]))",
          "legendFormat": "Error rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Total Tokens (24 h)",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"fixedColor": "blue", "mode": "fixed"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(increase(ai_gateway_request_token_total[24h]))",
          "legendFormat": "Tokens",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Cost per Request",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          },
          "unit": "currencyUSD",
          "decimals": 5
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(ai_gateway_request_cost_total[5m])) / sum(rate(ai_gateway_request_count_total[5m]))",
          "legendFormat": "$/req",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Request Volume by Model",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(ai_gateway_request_count_total{model_name=\"claude-haiku-3-5\"}[5m]))",
          "legendFormat": "claude-haiku-3-5",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(ai_gateway_request_count_total{model_name=\"claude-sonnet-4-5\"}[5m]))",
          "legendFormat": "claude-sonnet-4-5",
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(ai_gateway_request_count_total{model_name=\"gpt-4o\"}[5m]))",
          "legendFormat": "gpt-4o",
          "refId": "C"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(ai_gateway_request_count_total{model_name=\"claude-opus-4-6\"}[5m]))",
          "legendFormat": "claude-opus-4-6",
          "refId": "D"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Latency Percentiles (p50 / p95 / p99)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.50, sum(rate(ai_gateway_request_duration_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, sum(rate(ai_gateway_request_duration_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.99, sum(rate(ai_gateway_request_duration_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 9,
      "type": "barchart",
      "title": "Cost by Client (5 min rate)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 80},
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "options": {
        "barRadius": 0.05,
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "legend": {"displayMode": "list", "placement": "bottom"},
        "orientation": "horizontal",
        "stacking": "none",
        "tooltip": {"mode": "single"},
        "xTickLabelRotation": 0
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sort_desc(sum(rate(ai_gateway_request_cost_total[5m])) by (client_name))",
          "legendFormat": "{{client_name}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 10,
      "type": "piechart",
      "title": "Model Routing Mix (24 h)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {},
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "displayLabels": ["name", "percent"],
        "legend": {"displayMode": "list", "placement": "right"},
        "pieType": "donut",
        "tooltip": {"mode": "single"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(increase(ai_gateway_request_count_total[24h])) by (model_name)",
          "legendFormat": "{{model_name}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 11,
      "type": "barchart",
      "title": "Token Consumption by Type",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 20},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 80},
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "barRadius": 0.05,
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "legend": {"displayMode": "list", "placement": "bottom"},
        "orientation": "auto",
        "stacking": "normal",
        "tooltip": {"mode": "multi"},
        "xTickLabelRotation": 0
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(ai_gateway_request_token_total{token_type=\"prompt\"}[5m])) by (model_name)",
          "legendFormat": "prompt — {{model_name}}",
          "refId": "A",
          "instant": true
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(ai_gateway_request_token_total{token_type=\"completion\"}[5m])) by (model_name)",
          "legendFormat": "completion — {{model_name}}",
          "refId": "B",
          "instant": true
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(ai_gateway_request_token_total{token_type=\"cache_read\"}[5m])) by (model_name)",
          "legendFormat": "cache_read — {{model_name}}",
          "refId": "C",
          "instant": true
        }
      ]
    },
    {
      "id": 12,
      "type": "barchart",
      "title": "Exception Count by Model & Type",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 20},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"fixedColor": "red", "mode": "fixed"},
          "custom": {"fillOpacity": 80},
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "barRadius": 0.05,
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "legend": {"displayMode": "list", "placement": "bottom"},
        "orientation": "auto",
        "stacking": "none",
        "tooltip": {"mode": "multi"},
        "xTickLabelRotation": -30
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(increase(ai_gateway_exception_count_total[1h])) by (model_name, error_type)",
          "legendFormat": "{{model_name}} / {{error_type}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Request Rate — Success vs Error",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 20},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "reqpm"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Errors"},
            "properties": [
              {"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}
            ]
          }
        ]
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(ai_gateway_request_count_total{status=\"success\"}[1m])) * 60",
          "legendFormat": "Success",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(ai_gateway_request_count_total{status=\"error\"}[1m])) * 60",
          "legendFormat": "Errors",
          "refId": "B"
        }
      ]
    }
  ]
}
