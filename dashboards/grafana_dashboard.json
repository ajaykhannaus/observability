      "collapsed": false,
      "panels": []
    },

    {
      "id": 30,
      "type": "timeseries",
      "title": "Log Events per Minute",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 51},
      "datasource": {"type": "grafana-azure-monitor-datasource", "uid": "${azuremonitor}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10, "showPoints": "never"},
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "single"}
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "query": "ContainerAppConsoleLogs_CL\n| where ContainerAppName_s == 'ai-telemetry-runner'\n| where TimeGenerated > ago(3h)\n| extend e = parse_json(Log_s)\n| where e.event_type == 'telemetry_event'\n| summarize EventCount=count() by bin(TimeGenerated, 1m)\n| order by TimeGenerated asc",
            "resultFormat": "time_series"
          }
        }
      ]
    },

    {
      "id": 31,
      "type": "table",
      "title": "Recent ERROR Logs",
      "gridPos": {"h": 8, "w": 10, "x": 8, "y": 51},
      "datasource": {"type": "grafana-azure-monitor-datasource", "uid": "${azuremonitor}"},
      "fieldConfig": {
        "defaults": {"custom": {"align": "auto"}},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "TimeGenerated"},
            "properties": [{"id": "custom.width", "value": 180}]
          }
        ]
      },
      "options": {
        "sortBy": [{"displayName": "TimeGenerated", "desc": true}]
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "query": "ContainerAppConsoleLogs_CL\n| where ContainerAppName_s == 'ai-telemetry-runner'\n| where TimeGenerated > ago(1h)\n| extend e = parse_json(Log_s)\n| where e.level == 'ERROR'\n| project TimeGenerated, Message=tostring(e.message), Module=tostring(e.module), Exception=tostring(e.exception)\n| order by TimeGenerated desc\n| take 50",
            "resultFormat": "table"
          }
        }
      ]
    },

    {
      "id": 32,
      "type": "timeseries",
      "title": "Events by Model (from Logs)",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 51},
      "datasource": {"type": "grafana-azure-monitor-datasource", "uid": "${azuremonitor}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10, "showPoints": "never"},
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "query": "ContainerAppConsoleLogs_CL\n| where ContainerAppName_s == 'ai-telemetry-runner'\n| where TimeGenerated > ago(1h)\n| extend e = parse_json(Log_s)\n| where e.event_type == 'telemetry_event'\n| extend model = tostring(e.model_name)\n| summarize count() by bin(TimeGenerated, 5m), model\n| order by TimeGenerated asc",
            "resultFormat": "time_series"
          }
        }
      ]
    },

