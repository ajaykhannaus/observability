{
  "uid": "ai-telemetry-cost",
  "title": "4 \u2014 AI Gateway: Token & Cost Analytics",
  "description": "Token consumption, cost by model and tenant, budget utilisation, cache savings.",
  "tags": [
    "ai-telemetry",
    "cost",
    "tokens",
    "budget"
  ],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "DS_PROMETHEUS",
        "label": "Prometheus",
        "pluginId": "prometheus",
        "multi": false,
        "includeAll": false,
        "hide": 0,
        "refresh": 1,
        "current": {}
      },
      {
        "type": "datasource",
        "name": "DS_LOKI",
        "label": "Loki",
        "pluginId": "loki",
        "multi": false,
        "includeAll": false,
        "hide": 0,
        "refresh": 1,
        "current": {}
      },
      {
        "type": "datasource",
        "name": "DS_TEMPO",
        "label": "Tempo",
        "pluginId": "tempo",
        "multi": false,
        "includeAll": false,
        "hide": 0,
        "refresh": 1,
        "current": {}
      },
      {
        "type": "query",
        "name": "tenant",
        "label": "Tenant",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(ai_gateway_request_count_total, tenant_id)",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "hide": 0,
        "refresh": 2,
        "current": {},
        "sort": 1
      },
      {
        "type": "query",
        "name": "model",
        "label": "Model",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(ai_gateway_request_count_total, model_name)",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "hide": 0,
        "refresh": 2,
        "current": {},
        "sort": 1
      },
      {
        "type": "query",
        "name": "environment",
        "label": "Environment",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(ai_gateway_request_count_total, environment)",
        "multi": false,
        "includeAll": false,
        "allValue": ".*",
        "hide": 0,
        "refresh": 2,
        "current": {},
        "sort": 1
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "name": "Alerts",
        "type": "alert",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "enable": true,
        "hide": false,
        "iconColor": "red"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Cost Summary",
