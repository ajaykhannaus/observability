      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes * 100",
          "instant": true,
          "refId": "A"
