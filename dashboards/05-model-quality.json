{
  "uid": "ai-telemetry-quality",
  "title": "5 \u2014 AI Gateway: Model Quality & Evaluation",
  "description": "OpenAI-as-judge faithfulness, relevance, groundedness scores by model and operation.",
  "tags": [
    "ai-telemetry",
    "quality",
    "evaluation"
  ],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "DS_PROMETHEUS",
        "label": "Prometheus",
        "pluginId": "prometheus",
        "multi": false,
        "includeAll": false,
        "hide": 0,
        "refresh": 1,
        "current": {}
      },
      {
        "type": "datasource",
        "name": "DS_LOKI",
        "label": "Loki",
        "pluginId": "loki",
        "multi": false,
        "includeAll": false,
        "hide": 0,
        "refresh": 1,
        "current": {}
      },
      {
        "type": "datasource",
        "name": "DS_TEMPO",
        "label": "Tempo",
        "pluginId": "tempo",
        "multi": false,
        "includeAll": false,
        "hide": 0,
        "refresh": 1,
        "current": {}
      },
      {
        "type": "query",
        "name": "tenant",
        "label": "Tenant",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(ai_gateway_request_count_total, tenant_id)",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "hide": 0,
        "refresh": 2,
        "current": {},
        "sort": 1
      },
      {
        "type": "query",
        "name": "model",
        "label": "Model",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(ai_gateway_request_count_total, model_name)",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "hide": 0,
        "refresh": 2,
        "current": {},
        "sort": 1
      },
      {
        "type": "query",
        "name": "environment",
        "label": "Environment",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(ai_gateway_request_count_total, environment)",
        "multi": false,
        "includeAll": false,
        "allValue": ".*",
        "hide": 0,
        "refresh": 2,
        "current": {},
        "sort": 1
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "name": "Alerts",
        "type": "alert",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "enable": true,
        "hide": false,
        "iconColor": "red"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Quality Score Summary",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Avg Faithfulness",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "color": {
            "mode": "background"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 6
              },
              {
                "color": "green",
                "value": 8
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "auto"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          },
          "expr": "avg(avg_over_time({{service_name=~\".+\"} | json | event_type = \"eval_result\" | tenant_id =~ \"$tenant\"} | unwrap faithfulness [1h]))",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
