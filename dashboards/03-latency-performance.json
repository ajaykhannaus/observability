      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum(rate(ai_gateway_request_duration_sum[5m])) / clamp_min(sum(rate(ai_gateway_request_duration_count[5m])),1e-9)",
          "instant": true,
          "refId": "A"
        }
