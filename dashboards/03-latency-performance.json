    {
      "id": 11,
      "type": "barchart",
      "title": "Avg Latency Phase Breakdown by Model",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {
        "orientation": "auto",
        "xTickLabelRotation": -45,
        "barRadius": 0.03,
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "stacking": "none",
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          },
          "expr": "avg by (model_name) (avg_over_time({service_name=~\".+\"} | json | event_type=\"telemetry_event\" | unwrap queue_wait_ms [10m]))",
          "legendFormat": "queue_wait \u2014 {{model_name}}",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          },
          "expr": "avg by (model_name) (avg_over_time({service_name=~\".+\"} | json | event_type=\"telemetry_event\" | unwrap model_inference_ms [10m]))",
          "legendFormat": "inference \u2014 {{model_name}}",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          },
          "expr": "avg by (model_name) (avg_over_time({service_name=~\".+\"} | json | event_type=\"telemetry_event\" | unwrap stream_response_ms [10m]))",
          "legendFormat": "stream \u2014 {{model_name}}",
          "refId": "C"
        }
      ]
    },
