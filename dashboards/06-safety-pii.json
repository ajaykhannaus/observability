          },
          "expr": "sum(count_over_time({{service_name=~\".+\"} | json | event_type = \"prompt_log_event\" | pii_detected=\"true\" [5m]})) / clamp_min(sum(count_over_time({{service_name=~\".+\"} | json | event_type = \"prompt_log_event\" [5m]})),1) * 100",
          "legendFormat": "PII %",
          "refId": "A"
