{
  "uid": "ai-telemetry-safety",
  "title": "6 \u2014 AI Gateway: Safety & PII Compliance",
  "description": "PII detection rates, data classification, PHI/PII volumes, prompt audit log.",
  "tags": [
    "ai-telemetry",
    "safety",
    "pii",
    "compliance"
  ],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "DS_PROMETHEUS",
        "label": "Prometheus",
        "pluginId": "prometheus",
        "multi": false,
        "includeAll": false,
        "hide": 0,
        "refresh": 1,
        "current": {}
      },
      {
        "type": "datasource",
        "name": "DS_LOKI",
        "label": "Loki",
        "pluginId": "loki",
        "multi": false,
        "includeAll": false,
        "hide": 0,
        "refresh": 1,
        "current": {}
      },
      {
        "type": "datasource",
        "name": "DS_TEMPO",
        "label": "Tempo",
        "pluginId": "tempo",
        "multi": false,
        "includeAll": false,
        "hide": 0,
        "refresh": 1,
        "current": {}
      },
      {
        "type": "query",
        "name": "tenant",
        "label": "Tenant",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(ai_gateway_request_count_total, tenant_id)",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "hide": 0,
        "refresh": 2,
        "current": {},
        "sort": 1
      },
      {
        "type": "query",
        "name": "model",
        "label": "Model",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(ai_gateway_request_count_total, model_name)",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "hide": 0,
        "refresh": 2,
        "current": {},
        "sort": 1
      },
      {
        "type": "query",
        "name": "environment",
        "label": "Environment",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(ai_gateway_request_count_total, environment)",
        "multi": false,
        "includeAll": false,
        "allValue": ".*",
        "hide": 0,
        "refresh": 2,
        "current": {},
        "sort": 1
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "name": "Alerts",
        "type": "alert",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "enable": true,
        "hide": false,
        "iconColor": "red"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "PII Detection Summary",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "PII Detection Rate (24h)",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": {
            "mode": "background"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 15
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "auto"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          },
          "expr": "sum(count_over_time({{service_name=~\".+\"} | json | event_type = \"prompt_log_event\" | pii_detected=\"true\" [24h]})) / clamp_min(sum(count_over_time({{service_name=~\".+\"} | json | event_type = \"prompt_log_event\" [24h]})),1) * 100",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "PII Events Today",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "background"
          },
          "thresholds": {
            "mode": "absolute",
