    {
      "id": 7,
      "type": "piechart",
      "title": "Data Classification Distribution",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "pieType": "pie",
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": [
            "value",
            "percent"
          ]
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "gridPos": {
        "x": 20,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          },
          "expr": "sum by (data_classification) (count_over_time({{service_name=~\".+\"} | json | event_type = \"telemetry_event\" [1h]}))",
          "legendFormat": "{{data_classification}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
