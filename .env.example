# =============================================================================
# AI Gateway Telemetry — Environment Variables Template (dev naming)
# =============================================================================
# Copy this file to .env and fill in your values.
# .env is gitignored — NEVER commit real credentials.
#
# Local Azure deploy (no GitHub secrets):
#   cp .env.example .env
#   # Fill in AZURE_CLIENT_* below, then:
#   ./scripts/deploy-local.sh provision
#   ./scripts/deploy-local.sh all
# =============================================================================

# ── Azure Service Principal (local CLI auth only — not stored in GitHub) ─────
AZURE_CLIENT_ID=your-sp-client-id
AZURE_CLIENT_SECRET=your-sp-client-secret
AZURE_TENANT_ID=your-tenant-id
AZURE_SUBSCRIPTION_ID=your-subscription-id

# ── Dev resource names (defaults used by scripts/deploy-local.sh) ───────────
# If you cannot create resource groups, set USE_EXISTING_RG=true and put your
# company's existing resource group name in AZURE_RESOURCE_GROUP.
USE_EXISTING_RG=true
AZURE_RESOURCE_GROUP=your-company-resource-group-name
AZURE_LOCATION=eastus
ACR_NAME=acrtelemetrydev
ACR_LOGIN_SERVER=acrtelemetrydev.azurecr.io
CAE_NAME=cae-telemetry-dev
APP_NAME=ai-telemetry-runner-dev
PROM_APP_NAME=prometheus-scraper-dev
GRAFANA_NAME=grafana-ai-telemetry-dev
PROM_WS=telemetry-prometheus-dev
EH_NS=evhns-telemetry-dev

# ── Event Hubs (Kafka) — filled by: ./scripts/deploy-local.sh provision ───────
EVENTHUB_NAMESPACE=evhns-telemetry-dev.servicebus.windows.net
EVENTHUB_CONNECTION_STRING=Endpoint=sb://evhns-telemetry-dev.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=YOUR_KEY_HERE
EVENTHUB_NAME=ai-telemetry-events

# ── Azure Managed Prometheus — filled by provision ───────────────────────────
PROM_REMOTE_WRITE_URL=
AZURE_PROM_QUERY_URL=https://telemetry-prometheus-dev.eastus.prometheus.monitor.azure.com

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=ai-telemetry-dev
OTEL_EXPORT_INTERVAL_MS=30000

# ── Generator behaviour ───────────────────────────────────────────────────────
ENVIRONMENT=dev
ALLOW_MOCK_MODE=true
PROMETHEUS_PORT=8000
HEALTH_PORT=8080
BATCH_INTERVAL_S=5
BASE_BATCH_SIZE=8
ERROR_WINDOW_PROB=0.03
ERROR_WINDOW_MIN_S=90
ERROR_WINDOW_MAX_S=180
SIMULATE_LATENCY=false

# ── Bucket 2: PII scanner ────────────────────────────────────────────────────
PII_BACKEND=auto
PII_SAMPLE_RATE=1.0
PII_LOG_HITS=false

# ── Bucket 2: Prompt audit logging (FR-003, NFR-011) ─────────────────────────
PROMPT_LOG_ENABLED=true
AUDIT_BLOB_CONNECTION_STRING=
AUDIT_BLOB_CONTAINER=ai-audit-log-dev
AUDIT_LOCAL_PATH=/tmp/audit_log.jsonl

# ── Bucket 2: OpenAI-as-judge evaluator (FR-012) ───────────────────────────────
OPENAI_API_KEY=
EVAL_MODEL=gpt-4o-mini
EVAL_SAMPLE_RATE=0.01
EVAL_DAILY_TOKEN_BUDGET=50000
EVAL_ENABLED=false
EVAL_TIMEOUT_S=15

# ── Bucket 2: ADX audit store ─────────────────────────────────────────────────
ADX_CLUSTER_URI=
ADX_DATABASE=ai-telemetry-audit-dev
