# ─── Azure Event Hubs ────────────────────────────────────────────────────────
# Get the connection string with:
#   az eventhubs namespace authorization-rule keys list \
#     --resource-group rg-ai-telemetry-poc \
#     --namespace-name evhns-telemetry-poc \
#     --name RootManageSharedAccessKey \
#     --query primaryConnectionString -o tsv
EVENTHUB_NAMESPACE=evhns-telemetry-poc.servicebus.windows.net
EVENTHUB_CONNECTION_STRING=Endpoint=sb://evhns-telemetry-poc.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=YOUR_KEY_HERE
EVENTHUB_NAME=ai-telemetry-events

# ─── OpenTelemetry ───────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=ai-telemetry-poc
OTEL_EXPORT_INTERVAL_MS=30000

# ─── General ─────────────────────────────────────────────────────────────────
ENVIRONMENT=poc

# ─── Local runner only ───────────────────────────────────────────────────────
BATCH_INTERVAL_S=5
BASE_BATCH_SIZE=8
ERROR_WINDOW_PROB=0.03
ERROR_WINDOW_MIN_S=90
ERROR_WINDOW_MAX_S=180
SIMULATE_LATENCY=false
