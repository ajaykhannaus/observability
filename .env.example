AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=

USE_EXISTING_RG=true
AZURE_RESOURCE_GROUP=rg-telemetry-dev
