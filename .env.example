# =============================================================================
# AI Gateway Telemetry — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values.
# .env is gitignored — NEVER commit real credentials.
#
# Run infra/bootstrap.sh to provision Azure resources and get most values.
# =============================================================================

# ── Event Hubs (Kafka) ────────────────────────────────────────────────────────
# Get connection string:
#   az eventhubs namespace authorization-rule keys list \
#     --resource-group <your-rg> --namespace-name <your-ns> \
#     --name RootManageSharedAccessKey --query primaryConnectionString -o tsv
EVENTHUB_NAMESPACE=your-namespace.servicebus.windows.net
EVENTHUB_CONNECTION_STRING=Endpoint=sb://your-namespace.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=YOUR_KEY_HERE
EVENTHUB_NAME=ai-telemetry-events

# ── Azure Service Principal ───────────────────────────────────────────────────
# Used for local Prometheus remote_write auth.
# Container App uses Managed Identity automatically — no secret needed there.
# Get from bootstrap.sh output or: az ad sp create-for-rbac
AZURE_CLIENT_ID=your-sp-client-id
AZURE_CLIENT_SECRET=your-sp-client-secret
AZURE_TENANT_ID=your-tenant-id
AZURE_SUBSCRIPTION_ID=your-subscription-id

# ── Azure Managed Prometheus ──────────────────────────────────────────────────
# Get from: Azure Portal → Azure Monitor workspace → Query endpoint
AZURE_PROM_QUERY_URL=https://your-workspace.eastus.prometheus.monitor.azure.com

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=ai-telemetry
OTEL_EXPORT_INTERVAL_MS=30000

# ── Generator behaviour ───────────────────────────────────────────────────────
# ENVIRONMENT must be one of: prod, staging, dev. Defaults to "prod".
# In "prod", missing EVENTHUB_* credentials cause the runner to exit at startup.
# Set ALLOW_MOCK_MODE=true for local dev to allow the mock publisher to start.
ENVIRONMENT=dev
ALLOW_MOCK_MODE=true
PROMETHEUS_PORT=8000
HEALTH_PORT=8080
BATCH_INTERVAL_S=5
BASE_BATCH_SIZE=8
ERROR_WINDOW_PROB=0.03
ERROR_WINDOW_MIN_S=90
ERROR_WINDOW_MAX_S=180
SIMULATE_LATENCY=false
